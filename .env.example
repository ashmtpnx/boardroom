# Copy to .env to override. All values are optional — the app runs with these defaults.

# Realtime transport: "socket" (default — real cross-device sync via the relay) or
# "mock" (BroadcastChannel, cross-tab on ONE device, for local dev with no server).
# Multi-device messaging/notifications need "socket" and a reachable VITE_SOCKET_URL.
VITE_REALTIME=socket

# Auth provider: "mock" (instant zero-config user, default) or "firebase" (Google OAuth)
VITE_AUTH=mock

# Firebase config — only needed when VITE_AUTH=firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Socket server URL — only needed when VITE_REALTIME=socket (Pass 2)
VITE_SOCKET_URL=http://localhost:3001
