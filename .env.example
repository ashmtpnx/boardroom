# Copy to .env to override. All values are optional — the app runs with these defaults.

# Realtime transport: "mock" (BroadcastChannel, cross-tab, default) or "socket" (needs server, Pass 2)
VITE_REALTIME=mock

# Auth provider: "mock" (instant zero-config user, default) or "firebase" (Google OAuth)
VITE_AUTH=mock

# Firebase config — only needed when VITE_AUTH=firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Socket server URL — only needed when VITE_REALTIME=socket (Pass 2)
VITE_SOCKET_URL=http://localhost:3001
