# Copy to .env to override. All values are optional.

# Port the relay listens on (must match the frontend's VITE_SOCKET_URL).
PORT=3001

# Allowed browser origins (CORS). "*" allows any origin — fine for local dev.
# For production set the deployed frontend URL, e.g. https://boardroom.example.com
# Multiple origins: comma-separated.
CORS_ORIGIN=*
